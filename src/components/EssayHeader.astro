---
interface Props {
	authorSlug: string;
	byline: string;
	locationTag: string;
	title: string;
}

const {
	authorSlug,
	byline,
	locationTag,
	title,
} = Astro.props;
---
<div class="essay-header">
	<p class="location-tag">
		{locationTag}:
	</p>
	<h1 class="title">
		{title}
	</h1>
	<p class="byline">
		<a href={`/contributors#${authorSlug}`}>{byline}</a>
	</p>
</div>

<style>
.essay-header {
	margin: 2rem auto 4rem auto;
	max-width: 680px;
	width: 94%;
}

p.location-tag {
	color: var(--tertiary-text-color);
	font-family: 'Paix', sans-serif;
	font-size: 1rem;
	line-height: 125%;
	margin-bottom: 0;
	text-transform: uppercase;
}

h1.title {
	color: var(--primary-text-color);
	font-size: 2.5rem;
	font-weight: 400;
	line-height: 110%;
	margin: .75rem auto .5rem auto;
}

p.byline {
	color: var(--tertiary-text-color);
	font-size: 1.4rem;
	font-weight: 300;
	margin-top: 0;
}

p.byline a {
	color: var(--tertiary-text-color);
	text-decoration-color: transparent;
	transition: .1s all ease;
}

p.byline a:hover {
	color: var(--primary-text-color);
	text-decoration-color: var(--tertiary-text-color);
}
</style>
